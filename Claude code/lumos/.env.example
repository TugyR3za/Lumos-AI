# Copy this file to `.env` and fill in what you have.
# Lumos runs without any of these (echo provider + hashing embedder),
# but real answers and web search need a model and a search key.

# Cloud model fallback (free tier at https://console.groq.com)
GROQ_API_KEY=

# Web search (free tier at https://tavily.com)
TAVILY_API_KEY=
