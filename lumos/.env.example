# Lumos binds to localhost by default. Do not expose it publicly without authentication.
LUMOS_HOST=127.0.0.1
LUMOS_PORT=8000
LUMOS_ENVIRONMENT=development
LUMOS_LOG_LEVEL=INFO

# Storage. Relative paths resolve against the project folder, not the shell's
# current directory; absolute paths are used as-is.
LUMOS_DATABASE_PATH=data/lumos.db
LUMOS_NOTES_PATH=notes
LUMOS_INGEST_NOTES_ON_STARTUP=true

# Primary provider: Ollama, in one of two modes (preferred in auto routing).
#   cloud (default): Ollama Cloud at https://ollama.com — no downloads, no local
#                    RAM cost. Create an API key in your ollama.com account
#                    settings and put it in LUMOS_OLLAMA_API_KEY.
#   local:           an Ollama install on this machine — fully private. Install
#                    Ollama, then `ollama pull qwen3:1.7b`. No key needed.
LUMOS_OLLAMA_ENABLED=true
LUMOS_OLLAMA_MODE=cloud
LUMOS_OLLAMA_API_KEY=
# Blank = per-mode default (cloud: gpt-oss:20b, local: qwen3:1.7b).
LUMOS_OLLAMA_MODEL=
# Blank = per-mode default endpoint. Set only for e.g. an Ollama server on your LAN.
LUMOS_OLLAMA_BASE_URL=

# Fallback provider: any OpenAI-compatible endpoint; OpenRouter by default.
# Leave the key empty to disable fallback routing.
LUMOS_CLOUD_ENABLED=true
LUMOS_CLOUD_BASE_URL=https://openrouter.ai/api/v1
LUMOS_CLOUD_API_KEY=
LUMOS_CLOUD_MODEL=openai/gpt-4o-mini

# Echo fallback answers as a last resort in auto routing when no model works,
# so a fresh install can still respond. Set false to get hard errors instead.
LUMOS_ECHO_FALLBACK=true

# Web search: auto uses SearXNG when configured, otherwise DDGS.
LUMOS_WEB_SEARCH_PROVIDER=auto
LUMOS_SEARXNG_BASE_URL=
LUMOS_WEB_SEARCH_MAX_RESULTS=5

# Model-initiated durable memory writes are off until an approval UI exists.
# Saved memories (e.g. via the CLI /remember command) are always searched and
# injected into context each turn; LUMOS_MEMORY_TOP_K controls how many.
LUMOS_ALLOW_MODEL_MEMORY_WRITES=false
LUMOS_MEMORY_TOP_K=4
